{
  "name": "kaamfinder-india",
  "version": "1.0.0",
  "description": "KaamFinder India - Modern Job Portal for Local Job Opportunities",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --parallel",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build --workspaces",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "start": "npm run start --workspaces --parallel",
    "seed": "npm run seed -w backend",
    "install-all": "npm install && npm install -w frontend && npm install -w backend"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/kaamfinder-india"
  },
  "keywords": [
    "job-portal",
    "india",
    "labour",
    "employment",
    "workers"
  ],
  "author": "KaamFinder Team",
  "license": "MIT"
}
